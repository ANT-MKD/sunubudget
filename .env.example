# Copiez ce fichier en .env à la racine du projet. Ne commitez jamais .env.
#
# Supabase → Project Settings → API :
#   - Project URL  → VITE_SUPABASE_URL   (doit ressembler à https://xxxxxxxx.supabase.co)
#   - anon public  → VITE_SUPABASE_ANON_KEY (longue chaîne JWT, commence souvent par eyJ…)
#
# N’utilisez jamais https://placeholder.supabase.co (tutoriel) : ce domaine n’existe pas.

VITE_SUPABASE_URL=https://VOTRE_REF_PROJET.supabase.co
VITE_SUPABASE_ANON_KEY=
